{
  "validation": {
    "dictionaryUrl": "https://raw.githubusercontent.com/dolph/dictionary/master/enable1.txt",
    "minWordLength": 2,
    "requireCenterStart": true,
    "mustConnect": true,
    "allowCrossWords": true,
    "diagonalAllowed": false
  },
  "vectors": {
    "horizontal": {"step": 1, "check": "left-right"},
    "vertical": {"step": 11, "check": "up-down"}
  },
  "feedback": {
    "invalidIcon": "❌",
    "validColor": "var(--gold)",
    "errorColor": "#FF0000"
  }
}
